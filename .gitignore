# ─── IndoBangla ──────────────────────────────────────────────────────────────
# Secrets live on the server only. The repo must never carry a working key.
.env
.env.*
!.env.example
!.env.template

# Composer deps (reinstalled at build time)
vendor/

# Database dumps — huge, and full of real customer data
*.sql
*.sql.gz
*.dump

# Laravel runtime state
api/storage/logs/*
api/storage/framework/cache/*
api/storage/framework/sessions/*
api/storage/framework/views/*
api/bootstrap/cache/*
api/public/storage
# ─────────────────────────────────────────────────────────────────────────────

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.js
.next

# testing
/coverage
# *~
*.swp
tmp/
# production
build

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

# If Packages have their independent repo
# /packages

# ignore log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.idea/
.vscode/
node_modules/
build
.DS_Store
*.tgz
my-app*
template/src/__tests__/__snapshots__/
lerna-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/.changelog
.npm/
packages/server/node_modules
packages/server/error.log
packages/server/debug.log
packages/web/.env
packages/reusecore
packages/cloud
dist/

.docz
.now
.vercel
# PWA
workbox-*.js
sw.js
# Server-only deploy state (secrets, build logs, DB dumps)
deploy/.env*
deploy/*.log
deploy/*.sh
!deploy/build_all.sh
!deploy/api-entrypoint.sh
!deploy/stage.sh
!deploy/promote.sh
!deploy/rollback.sh
deploy/*.bak
deploy/*.presecret
